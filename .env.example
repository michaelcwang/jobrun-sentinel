# Container mode keeps the app fully functional without Oracle credentials.
# For local non-Docker development, override with:
# DATABASE_URL=sqlite:///./jobrun_sentinel.db
DATABASE_URL=postgresql+psycopg2://sentinel:sentinel@db:5432/jobrun_sentinel
AUTO_SEED=true
AUTO_SEED_SCALE=false
ENVIRONMENT=local

# Container deployment defaults.
POSTGRES_USER=sentinel
POSTGRES_PASSWORD=sentinel
POSTGRES_DB=jobrun_sentinel
POSTGRES_PORT=5432
API_PORT=8000
FRONTEND_PORT=5173
JOBRUN_API_IMAGE=jobrun-sentinel-api:local
JOBRUN_FRONTEND_IMAGE=jobrun-sentinel-frontend:local
API_UPSTREAM=http://api:8000
JOBRUN_DB_WAIT_SECONDS=90
JOBRUN_RUN_MIGRATIONS=false
DEFAULT_ALERT_DASHBOARD_URL=http://localhost:5173/dashboard

JOBRUN_CONNECTOR_MODE=mock
JOBRUN_ALLOW_ORACLE_CONNECTOR=false
JOBRUN_ALLOW_RAW_QUERY_TEXT=false
JOBRUN_ORACLE_DEFAULT_CONFIG_KEY=demo
JOBRUN_ORACLE_QUERY_TIMEOUT_SECONDS=60
JOBRUN_ORACLE_FETCH_LIMIT=500
JOBRUN_ORACLE_CONNECT_TIMEOUT_SECONDS=15

# Optional scheduler. Disabled by default for local development.
JOBRUN_SCHEDULER_ENABLED=false
JOBRUN_SCHEDULER_INTERVAL_SECONDS=300
JOBRUN_SCHEDULER_MAX_CONCURRENCY=2

# Optional SQL allowlist. Leave empty locally. When configured, use JSON list syntax.
# JOBRUN_SQL_ALLOWLIST=["mock_icm_job_status","mock_icm_job_history"]

# Example per-connector env vars. Do not require these locally.
# Production should use one prefix per route, for example JOBRUN_ORACLE_PROD1.
# ConnectorConfig.env_var_prefix points to the prefix; secrets stay in env or a secrets manager.
JOBRUN_ORACLE_DEMO_USER=
JOBRUN_ORACLE_DEMO_PASSWORD=
JOBRUN_ORACLE_DEMO_DSN=
JOBRUN_ORACLE_DEMO_TNS_ADMIN=
JOBRUN_ORACLE_DEMO_WALLET_LOCATION=
JOBRUN_ORACLE_DEMO_WALLET_PASSWORD=
JOBRUN_ORACLE_DEMO_CLIENT_MODE=thin
JOBRUN_ORACLE_DEMO_QUERY_TIMEOUT_SECONDS=
JOBRUN_ORACLE_DEMO_FETCH_LIMIT=
JOBRUN_ORACLE_DEMO_CONNECT_TIMEOUT_SECONDS=

# Optional remote catalog skeleton. Bundled local catalog works without these.
JOBRUN_QUERY_CATALOG_SOURCE_URL=
JOBRUN_CONFLUENCE_PAT=
JOBRUN_CONFLUENCE_USERNAME=
JOBRUN_CONFLUENCE_BASE_URL=
